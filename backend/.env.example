# VitaAI Backend — Environment Variables
# Copy this file to .env and fill in the values

# SQLite database path (relative to where uvicorn is launched from)
DATABASE_URL=sqlite:///./vitaai.db

# JWT secret key — change this to a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# JWT algorithm (HS256 recommended)
ALGORITHM=HS256

# Token expiry in minutes (default: 7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Anthropic API key for Claude AI features (parse_report, interpret_record)
# Leave empty to use mock responses (useful for local dev without API key)
ANTHROPIC_API_KEY=
